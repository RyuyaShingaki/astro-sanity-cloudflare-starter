---
import Layout from "../../layouts/Layout.astro";
import { sanityFetch } from "../../lib/sanity";
import { POSTS_QUERY } from "../../lib/queries";
import type { POSTS_QUERY_RESULT } from "../../sanity.types";

const posts = (await sanityFetch<POSTS_QUERY_RESULT>(POSTS_QUERY)) ?? [];
---

<Layout title="ブログ | Example" description="記事一覧です。">
  <main class="mx-auto max-w-3xl px-4 py-16">
    <h1 class="text-3xl font-bold">ブログ</h1>
    {
      posts.length === 0 ? (
        <p class="mt-6 text-gray-600">記事はまだありません。</p>
      ) : (
        <ul class="mt-8 space-y-6">
          {posts.map((post) => (
            <li>
              <a
                href={`/blog/${post.slug}`}
                class="text-lg font-semibold text-blue-600 hover:underline"
              >
                {post.title}
              </a>
              {post.excerpt && <p class="mt-1 text-gray-600">{post.excerpt}</p>}
            </li>
          ))}
        </ul>
      )
    }
  </main>
</Layout>
