---
import Layout from "../layouts/Layout.astro";
import { organization, website } from "../lib/structured-data";

const siteName = "Example";
const siteUrl = Astro.site?.href ?? Astro.url.origin;
const jsonLd = [
  organization({ name: siteName, url: siteUrl }),
  website({ name: siteName, url: siteUrl }),
];
---

<Layout
  title={`${siteName} | コーポレートサイト`}
  description="Astro × Tailwind CSS v4 × Sanity × Resend × Cloudflare Workers のテンプレートです。"
  jsonLd={jsonLd}
>
  <main class="mx-auto max-w-3xl px-4 py-16">
    <h1 class="text-3xl font-bold">{siteName}</h1>
    <p class="mt-4 text-gray-600">テンプレートの雛形ページです。</p>
  </main>
</Layout>
